# config server
NODE_ENV
PORT

# secret
JWT_SECRET
JWT_EXPIRES_IN

# database config
# PostgreSQL (primary)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=cma_db
PG_USER=postgres
PG_PASSWORD=

# PostgreSQL SSL (set to "true" for cloud-hosted PG like Supabase/Neon)
PG_SSL=false

# firebase config (optional — kept for hybrid mode)
FIREBASE_CREDENTIALS

# storage config
# cloudinary config
CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET

# admin seed data
ADMIN_EMAIL
ADMIN_DEFAULT_PASSWORD

# redis config
REDIS_HOST
REDIS_PORT
REDIS_PASSWORD

# redis tls if need
REDIS_TLS

# Storage Provider (local | cloudflare_r2 | cloudinary | aws_s3)
STORAGE_PROVIDER=local

# Cloudflare R2 (when STORAGE_PROVIDER=cloudflare_r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cma-storage
R2_PUBLIC_URL=

# MongoDB (for Logs, Notifications, Analytics)
MONGO_URI=
MONGO_DATABASE=cma_logs
